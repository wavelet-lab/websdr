{
    "name": "websdr",
    "description": "WebSDR package",
    "author": "Timur Davydov <dtv.comp@gmail.com>",
    "license": "MIT",
    "homepage": "https://docs.wsdr.io/webdev/websdr/websdr.html",
    "repository": {
        "type": "git",
        "url": "https://github.com/wavelet-lab/websdr"
    },
    "keywords": [
        "radio",
        "websdr",
        "webusb",
        "sdr",
        "wsdr",
        "wavelet",
        "usdr",
        "xsdr",
        "ssdr"
    ],
    "private": true,
    "type": "module",
    "workspaces": [
        "./packages/core",
        "./packages/nestjs-microservice",
        "./packages/frontend-core",
        "./packages/vue3-components"
    ],
    "scripts": {
        "build": "npm run build --workspaces",
        "docs:diagrams": "node scripts/render-mermaid.js docs",
        "docs:diagrams:ubuntu": "MMD_AAEXEC=1 node scripts/render-mermaid.js docs",
        "test": "npm run test --workspaces",
        "test:all": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui"
    },
    "devDependencies": {
        "@mermaid-js/mermaid-cli": "^11.15.0",
        "@vitest/coverage-v8": "^4.1.9",
        "tsc-alias": "^1.8.17",
        "tsc-esm-fix": "^3.1.2",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.9"
    }
}
