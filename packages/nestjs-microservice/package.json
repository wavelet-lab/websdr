{
    "name": "@websdr/nestjs-microservice",
    "version": "0.5.0",
    "description": "This is a NestJS microservice for WebSDR",
    "author": "Timur Davydov <dtv.comp@gmail.com>",
    "license": "MIT",
    "keywords": [
        "nestjs",
        "microservice",
        "websdr",
        "auth",
        "users",
        "jwt"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsc && tsc-alias && tsc-esm-fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.13",
        "@nestjs/config": "^4.0.3",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/microservices": "^11.1.13",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/testing": "^11.1.13",
        "@nestjs/websockets": "^11.1.13",
        "@types/node": "^25.2.3",
        "@websdr/core": "^0.5.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "passport-jwt": "^4.0.1",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/passport-jwt": "^4.0.1",
        "@types/ws": "^8.18.1"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./common": {
            "types": "./dist/common/index.d.ts",
            "import": "./dist/common/index.js",
            "require": "./dist/common/index.js"
        },
        "./auth": {
            "types": "./dist/auth/index.d.ts",
            "import": "./dist/auth/index.js",
            "require": "./dist/auth/index.js"
        },
        "./users": {
            "types": "./dist/users/index.d.ts",
            "import": "./dist/users/index.js",
            "require": "./dist/users/index.js"
        }
    }
}
